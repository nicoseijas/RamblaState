# The repository is LF end-to-end: files are stored with LF and checked out
# with LF on every platform, regardless of the machine's core.autocrlf. This
# keeps `dotnet format --verify-no-changes` (which enforces .editorconfig's
# end_of_line = lf) green on both Windows and CI.
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.ico binary
*.snk binary
