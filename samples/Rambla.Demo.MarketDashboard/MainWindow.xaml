<Window x:Class="Rambla.Demo.MarketDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rambla — Real-Time Market Dashboard" Height="720" Width="1180"
        Background="#0E1116" TextElement.Foreground="#E6EDF3"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="StatLabel">
            <Setter Property="Foreground" Value="#8B949E" />
            <Setter Property="FontSize" Value="11" />
        </Style>
        <Style TargetType="TextBlock" x:Key="StatValue">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style TargetType="Border" x:Key="Card">
            <Setter Property="Background" Value="#161B22" />
            <Setter Property="BorderBrush" Value="#30363D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="4" />
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4,0,4,8">
            <TextBlock Text="Rambla" FontSize="22" FontWeight="Bold" Foreground="#58A6FF" />
            <TextBlock Text="  High-frequency observable state — background writes coalesced to the UI"
                       VerticalAlignment="Bottom" Margin="8,0,0,2" Foreground="#8B949E" />
        </StackPanel>

        <!-- Controls -->
        <Border Grid.Row="1" Style="{StaticResource Card}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Mode" Style="{StaticResource StatLabel}" VerticalAlignment="Center" Margin="0,0,6,0" />
                <ComboBox Width="180" ItemsSource="{Binding Modes}" SelectedItem="{Binding Mode}" Margin="0,0,16,0" />

                <TextBlock Text="Symbols" Style="{StaticResource StatLabel}" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox Width="70" Text="{Binding SymbolCount, UpdateSourceTrigger=LostFocus}" Margin="0,0,16,0" />

                <TextBlock Text="Target quotes/s" Style="{StaticResource StatLabel}" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox Width="90" Text="{Binding TargetRate, UpdateSourceTrigger=LostFocus}" Margin="0,0,16,0" />

                <TextBlock Text="Refresh Hz" Style="{StaticResource StatLabel}" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBox Width="60" Text="{Binding RefreshHz, UpdateSourceTrigger=LostFocus}" Margin="0,0,16,0" />

                <Button x:Name="StartButton" Content="Start" Width="90" Click="StartButton_Click"
                        Background="#238636" Foreground="White" BorderThickness="0" Padding="0,4" Margin="0,0,8,0" />
                <Button x:Name="StopButton" Content="Stop" Width="90" Click="StopButton_Click"
                        Background="#B62324" Foreground="White" BorderThickness="0" Padding="0,4" />
            </WrapPanel>
        </Border>

        <!-- Stat cards -->
        <StackPanel Grid.Row="2">
        <UniformGrid Rows="1" Columns="7">
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="INCOMING MUTATIONS/S" Style="{StaticResource StatLabel}" />
                    <TextBlock Text="{Binding IncomingPerSec, StringFormat=N0}" Style="{StaticResource StatValue}" Foreground="#F0883E" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="PROPERTYCHANGED/S" Style="{StaticResource StatLabel}" />
                    <TextBlock Text="{Binding NotificationsPerSec, StringFormat=N0}" Style="{StaticResource StatValue}" Foreground="#58A6FF" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="SCHEDULER POSTS/S" Style="{StaticResource StatLabel}" />
                    <TextBlock Text="{Binding PostsPerSec, StringFormat=N0}" Style="{StaticResource StatValue}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="COALESCING" Style="{StaticResource StatLabel}" />
                    <TextBlock Text="{Binding CoalescingPercent, StringFormat={}{0:N2}%}" Style="{StaticResource StatValue}" Foreground="#3FB950" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="FLUSH p50" Style="{StaticResource StatLabel}" />
                    <TextBlock Text="{Binding FlushP50Ms, StringFormat={}{0:N3} ms}" Style="{StaticResource StatValue}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="FLUSH p95 / p99" Style="{StaticResource StatLabel}" />
                    <TextBlock Style="{StaticResource StatValue}">
                        <Run Text="{Binding FlushP95Ms, StringFormat={}{0:N2}}" />
                        <Run Text=" / " Foreground="#8B949E" />
                        <Run Text="{Binding FlushP99Ms, StringFormat={}{0:N2}}" />
                        <Run Text=" ms" Foreground="#8B949E" FontSize="12" />
                    </TextBlock>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="UI LAG (max/s)" Style="{StaticResource StatLabel}" />
                    <TextBlock Text="{Binding UiLagMaxMs, StringFormat={}{0:N1} ms}" Style="{StaticResource StatValue}" Foreground="#DB6D28" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Producer -> visible latency (the macrobenchmark) -->
        <TextBlock Text="PRODUCER → VISIBLE LATENCY (end-to-end)" Style="{StaticResource StatLabel}"
                   Margin="8,6,0,0" FontWeight="SemiBold" />
        <UniformGrid Rows="1" Columns="3">
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="LATENCY p50" Style="{StaticResource StatLabel}" />
                    <TextBlock Text="{Binding LatencyP50Ms, StringFormat={}{0:N1} ms}" Style="{StaticResource StatValue}" Foreground="#A5D6FF" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="LATENCY p95" Style="{StaticResource StatLabel}" />
                    <TextBlock Text="{Binding LatencyP95Ms, StringFormat={}{0:N1} ms}" Style="{StaticResource StatValue}" Foreground="#F0883E" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="LATENCY p99" Style="{StaticResource StatLabel}" />
                    <TextBlock Text="{Binding LatencyP99Ms, StringFormat={}{0:N1} ms}" Style="{StaticResource StatValue}" Foreground="#DB6D28" />
                </StackPanel>
            </Border>
        </UniformGrid>
        </StackPanel>

        <!-- Grid of symbols -->
        <Border Grid.Row="3" Style="{StaticResource Card}">
            <DataGrid ItemsSource="{Binding Rows}" AutoGenerateColumns="False" IsReadOnly="True"
                      HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      Background="Transparent" Foreground="#E6EDF3" BorderThickness="0"
                      RowBackground="#161B22" AlternatingRowBackground="#1B222B"
                      EnableRowVirtualization="True" EnableColumnVirtualization="True"
                      VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="110" />
                    <DataGridTextColumn Header="Bid" Binding="{Binding Bid, StringFormat=N2}" Width="*" />
                    <DataGridTextColumn Header="Ask" Binding="{Binding Ask, StringFormat=N2}" Width="*" />
                    <DataGridTextColumn Header="Last" Binding="{Binding Last, StringFormat=N2}" Width="*" />
                    <DataGridTextColumn Header="Volume" Binding="{Binding Volume, StringFormat=N0}" Width="*" />
                    <DataGridTextColumn Header="PnL" Binding="{Binding Pnl, StringFormat=N2}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Status bar -->
        <TextBlock Grid.Row="4" Text="{Binding StatusText}" Foreground="#8B949E" Margin="6,8,0,0" />
    </Grid>
</Window>
